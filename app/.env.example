# Copy to .env in this folder (app/) for local development.
# Vite only exposes variables prefixed with VITE_.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: set the same URL as VITE_SUPABASE_URL if using Edge Functions (default is derived in code).
